---
interface Props {
  title: string;
  subtitle?: string;
  centered?: boolean;
  tag?: string;
}

const { title, subtitle, centered = true, tag } = Astro.props;
---

<div class={`mb-12 lg:mb-16 ${centered ? 'text-center' : ''}`}>
  {tag && (
    <span class="inline-block px-3 py-1 bg-primary-light text-primary text-sm font-bold rounded-full mb-4">
      {tag}
    </span>
  )}
  <h2 class="font-outfit font-bold text-3xl lg:text-[40px] text-text leading-tight">
    {title}
  </h2>
  {subtitle && (
    <p class={`mt-4 text-text-secondary text-lg leading-relaxed ${centered ? 'max-w-2xl mx-auto' : ''}`}>
      {subtitle}
    </p>
  )}
</div>
