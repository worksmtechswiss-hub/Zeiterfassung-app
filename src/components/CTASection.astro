---
import { ctaUrl } from '../data/navigation';

interface Props {
  title?: string;
  subtitle?: string;
  buttonText?: string;
  buttonHref?: string;
}

const {
  title = '30 Tage kostenlos testen',
  subtitle = 'Alle Features. Keine Kreditkarte. Keine Verpflichtung. Schweizer Qualität.',
  buttonText = 'Jetzt kostenlos testen',
  buttonHref = ctaUrl,
} = Astro.props;
---

<section class="bg-primary py-16 lg:py-24">
  <div class="max-w-container mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h2 class="font-outfit font-bold text-3xl lg:text-4xl text-white leading-tight">
      {title}
    </h2>
    <p class="mt-4 text-white/80 text-lg max-w-xl mx-auto">
      {subtitle}
    </p>
    <a
      href={buttonHref}
      class="inline-flex items-center justify-center mt-8 px-8 py-3.5 bg-white text-primary font-bold text-base rounded-button hover:bg-gray-50 transition-colors shadow-lg"
    >
      {buttonText}
    </a>
  </div>
</section>
