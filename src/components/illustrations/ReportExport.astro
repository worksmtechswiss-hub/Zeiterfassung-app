---
// Animated report/export illustration
---
<div class="relative w-full">
  <svg viewBox="0 0 480 360" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-auto drop-shadow-xl">
    <!-- Main document -->
    <rect x="80" y="20" width="320" height="320" rx="8" fill="white" stroke="#E2E2EA" stroke-width="1.5"/>

    <!-- Document header -->
    <rect x="80" y="20" width="320" height="60" rx="8" fill="#F8F8FC"/>
    <rect x="80" y="72" width="320" height="8" fill="#F8F8FC"/>

    <!-- Company Logo placeholder -->
    <rect x="100" y="36" width="32" height="32" rx="6" fill="#0066CC"/>
    <text x="116" y="57" text-anchor="middle" font-family="system-ui" font-weight="900" font-size="16" fill="white">Z</text>

    <text x="144" y="50" font-family="system-ui" font-weight="700" font-size="13" fill="#1A1A2E">Stundenrapport</text>
    <text x="144" y="66" font-family="system-ui" font-weight="400" font-size="10" fill="#8888A0">März 2026 · Sandra Klein</text>
    <text x="380" y="50" text-anchor="end" font-family="system-ui" font-weight="700" font-size="11" fill="#0066CC">PDF</text>
    <text x="380" y="66" text-anchor="end" font-family="system-ui" font-weight="400" font-size="10" fill="#8888A0">Seite 1/2</text>

    <!-- Table header -->
    <g transform="translate(100, 96)">
      <rect x="0" y="0" width="280" height="24" rx="4" fill="#F8F8FC"/>
      <text x="8" y="16" font-family="system-ui" font-weight="600" font-size="9" fill="#8888A0">Datum</text>
      <text x="70" y="16" font-family="system-ui" font-weight="600" font-size="9" fill="#8888A0">Projekt</text>
      <text x="160" y="16" font-family="system-ui" font-weight="600" font-size="9" fill="#8888A0">Aktivität</text>
      <text x="248" y="16" font-family="system-ui" font-weight="600" font-size="9" fill="#8888A0">Stunden</text>
    </g>

    <!-- Table rows with staggered fade-in -->
    <g transform="translate(100, 126)">
      <line x1="0" y1="24" x2="280" y2="24" stroke="#E2E2EA" stroke-width="0.5"/>
      <text x="8" y="16" font-family="system-ui" font-weight="400" font-size="10" fill="#4A4A68">01.03.</text>
      <text x="70" y="16" font-family="system-ui" font-weight="400" font-size="10" fill="#4A4A68">Website Redesign</text>
      <text x="160" y="16" font-family="system-ui" font-weight="400" font-size="10" fill="#4A4A68">Design</text>
      <text x="260" y="16" text-anchor="end" font-family="system-ui" font-weight="700" font-size="10" fill="#1A1A2E">8:00</text>
      <rect x="0" y="0" width="280" height="24" fill="white" opacity="0">
        <animate attributeName="opacity" values="1;0" dur="0.5s" begin="0s" fill="freeze"/>
      </rect>
    </g>

    <g transform="translate(100, 150)">
      <line x1="0" y1="24" x2="280" y2="24" stroke="#E2E2EA" stroke-width="0.5"/>
      <text x="8" y="16" font-family="system-ui" font-weight="400" font-size="10" fill="#4A4A68">02.03.</text>
      <text x="70" y="16" font-family="system-ui" font-weight="400" font-size="10" fill="#4A4A68">Website Redesign</text>
      <text x="160" y="16" font-family="system-ui" font-weight="400" font-size="10" fill="#4A4A68">Entwicklung</text>
      <text x="260" y="16" text-anchor="end" font-family="system-ui" font-weight="700" font-size="10" fill="#1A1A2E">7:30</text>
    </g>

    <g transform="translate(100, 174)">
      <line x1="0" y1="24" x2="280" y2="24" stroke="#E2E2EA" stroke-width="0.5"/>
      <text x="8" y="16" font-family="system-ui" font-weight="400" font-size="10" fill="#4A4A68">03.03.</text>
      <text x="70" y="16" font-family="system-ui" font-weight="400" font-size="10" fill="#4A4A68">App Development</text>
      <text x="160" y="16" font-family="system-ui" font-weight="400" font-size="10" fill="#4A4A68">Testing</text>
      <text x="260" y="16" text-anchor="end" font-family="system-ui" font-weight="700" font-size="10" fill="#1A1A2E">8:30</text>
    </g>

    <g transform="translate(100, 198)">
      <line x1="0" y1="24" x2="280" y2="24" stroke="#E2E2EA" stroke-width="0.5"/>
      <text x="8" y="16" font-family="system-ui" font-weight="400" font-size="10" fill="#4A4A68">04.03.</text>
      <text x="70" y="16" font-family="system-ui" font-weight="400" font-size="10" fill="#4A4A68">Beratung</text>
      <text x="160" y="16" font-family="system-ui" font-weight="400" font-size="10" fill="#4A4A68">Kundengespräch</text>
      <text x="260" y="16" text-anchor="end" font-family="system-ui" font-weight="700" font-size="10" fill="#1A1A2E">3:00</text>
    </g>

    <g transform="translate(100, 222)">
      <line x1="0" y1="24" x2="280" y2="24" stroke="#E2E2EA" stroke-width="0.5"/>
      <text x="8" y="16" font-family="system-ui" font-weight="400" font-size="10" fill="#4A4A68">05.03.</text>
      <text x="70" y="16" font-family="system-ui" font-weight="400" font-size="10" fill="#4A4A68">Website Redesign</text>
      <text x="160" y="16" font-family="system-ui" font-weight="400" font-size="10" fill="#4A4A68">Deployment</text>
      <text x="260" y="16" text-anchor="end" font-family="system-ui" font-weight="700" font-size="10" fill="#1A1A2E">6:00</text>
    </g>

    <!-- Total row -->
    <g transform="translate(100, 256)">
      <rect x="0" y="0" width="280" height="28" rx="4" fill="#E8F2FF"/>
      <text x="8" y="18" font-family="system-ui" font-weight="700" font-size="11" fill="#0066CC">Total</text>
      <text x="260" y="18" text-anchor="end" font-family="system-ui" font-weight="900" font-size="13" fill="#0066CC">
        33:00h
        <animate attributeName="opacity" values="0.7;1;0.7" dur="2s" repeatCount="indefinite"/>
      </text>
    </g>

    <!-- Signature line -->
    <g transform="translate(100, 300)">
      <line x1="0" y1="0" x2="120" y2="0" stroke="#E2E2EA" stroke-width="1"/>
      <text x="0" y="14" font-family="system-ui" font-weight="400" font-size="8" fill="#8888A0">Unterschrift Mitarbeitende</text>
      <line x1="160" y1="0" x2="280" y2="0" stroke="#E2E2EA" stroke-width="1"/>
      <text x="160" y="14" font-family="system-ui" font-weight="400" font-size="8" fill="#8888A0">Unterschrift Vorgesetzte</text>
    </g>

    <!-- Floating export buttons -->
    <g transform="translate(12, 120)">
      <rect x="0" y="0" width="56" height="56" rx="12" fill="white" stroke="#E2E2EA" stroke-width="1.5" filter="url(#exportShadow)"/>
      <text x="28" y="30" text-anchor="middle" font-family="system-ui" font-weight="900" font-size="11" fill="#DC2626">PDF</text>
      <text x="28" y="44" text-anchor="middle" font-family="system-ui" font-weight="400" font-size="7" fill="#8888A0">Export</text>
      <animate attributeName="opacity" values="0.5;1;0.5" dur="3s" repeatCount="indefinite"/>
    </g>

    <g transform="translate(12, 188)">
      <rect x="0" y="0" width="56" height="56" rx="12" fill="white" stroke="#E2E2EA" stroke-width="1.5" filter="url(#exportShadow)"/>
      <text x="28" y="30" text-anchor="middle" font-family="system-ui" font-weight="900" font-size="11" fill="#10B981">CSV</text>
      <text x="28" y="44" text-anchor="middle" font-family="system-ui" font-weight="400" font-size="7" fill="#8888A0">Export</text>
      <animate attributeName="opacity" values="0.5;1;0.5" dur="3s" begin="0.5s" repeatCount="indefinite"/>
    </g>

    <g transform="translate(12, 256)">
      <rect x="0" y="0" width="56" height="56" rx="12" fill="white" stroke="#E2E2EA" stroke-width="1.5" filter="url(#exportShadow)"/>
      <text x="28" y="30" text-anchor="middle" font-family="system-ui" font-weight="900" font-size="10" fill="#0066CC">XLS</text>
      <text x="28" y="44" text-anchor="middle" font-family="system-ui" font-weight="400" font-size="7" fill="#8888A0">Export</text>
      <animate attributeName="opacity" values="0.5;1;0.5" dur="3s" begin="1s" repeatCount="indefinite"/>
    </g>

    <defs>
      <filter id="exportShadow">
        <feDropShadow dx="0" dy="2" stdDeviation="4" flood-color="#1A1A2E" flood-opacity="0.1"/>
      </filter>
    </defs>
  </svg>
</div>
