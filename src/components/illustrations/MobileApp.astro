---
// Animated mobile phone mockup
---
<div class="relative w-full max-w-xs mx-auto">
  <svg viewBox="0 0 260 500" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-auto drop-shadow-2xl">
    <!-- Phone Frame -->
    <rect x="10" y="10" width="240" height="480" rx="32" fill="#1A1A2E" stroke="#2a2a4e" stroke-width="2"/>
    <!-- Screen -->
    <rect x="18" y="18" width="224" height="464" rx="26" fill="white"/>
    <!-- Status bar -->
    <rect x="18" y="18" width="224" height="40" rx="26" fill="#F8F8FC"/>
    <rect x="18" y="44" width="224" height="14" fill="#F8F8FC"/>
    <!-- Notch -->
    <rect x="90" y="22" width="80" height="24" rx="12" fill="#1A1A2E"/>
    <circle cx="130" cy="34" r="5" fill="#2a2a4e"/>

    <!-- App Header -->
    <rect x="30" y="68" width="80" height="10" rx="4" fill="#1A1A2E"/>
    <rect x="30" y="82" width="120" height="7" rx="3" fill="#8888A0"/>
    <rect x="196" y="66" width="34" height="34" rx="17" fill="#0066CC">
      <animate attributeName="opacity" values="1;0.7;1" dur="2s" repeatCount="indefinite"/>
    </rect>
    <text x="213" y="88" text-anchor="middle" font-family="system-ui" font-weight="700" font-size="14" fill="white">+</text>

    <!-- Timer Card -->
    <g transform="translate(30, 112)">
      <rect x="0" y="0" width="200" height="120" rx="12" fill="#0066CC"/>
      <!-- Timer display -->
      <text x="100" y="42" text-anchor="middle" font-family="system-ui" font-weight="200" font-size="36" fill="white">
        03:24:18
      </text>
      <text x="100" y="62" text-anchor="middle" font-family="system-ui" font-weight="400" font-size="11" fill="rgba(255,255,255,0.7)">
        Website Redesign
      </text>
      <!-- Animated progress ring -->
      <circle cx="100" cy="90" r="14" fill="none" stroke="rgba(255,255,255,0.2)" stroke-width="3"/>
      <circle cx="100" cy="90" r="14" fill="none" stroke="white" stroke-width="3" stroke-linecap="round" stroke-dasharray="88" stroke-dashoffset="22" transform="rotate(-90 100 90)">
        <animate attributeName="stroke-dashoffset" values="88;22;88" dur="10s" repeatCount="indefinite"/>
      </circle>
      <!-- Pause button -->
      <rect x="90" y="82" width="5" height="14" rx="1.5" fill="white">
        <animate attributeName="opacity" values="1;0.5;1" dur="1s" repeatCount="indefinite"/>
      </rect>
      <rect x="99" y="82" width="5" height="14" rx="1.5" fill="white">
        <animate attributeName="opacity" values="1;0.5;1" dur="1s" repeatCount="indefinite"/>
      </rect>
    </g>

    <!-- Today's entries -->
    <text x="30" y="258" font-family="system-ui" font-weight="700" font-size="12" fill="#1A1A2E">Heute</text>

    <!-- Entry 1 -->
    <g transform="translate(30, 268)">
      <rect x="0" y="0" width="200" height="48" rx="8" fill="#F8F8FC"/>
      <circle cx="16" cy="24" r="6" fill="#10B981"/>
      <rect x="30" y="14" width="80" height="7" rx="3" fill="#1A1A2E"/>
      <rect x="30" y="26" width="60" height="6" rx="3" fill="#8888A0"/>
      <text x="170" y="20" text-anchor="end" font-family="system-ui" font-weight="700" font-size="11" fill="#1A1A2E">2:15h</text>
      <text x="170" y="32" text-anchor="end" font-family="system-ui" font-weight="400" font-size="9" fill="#10B981">fertig</text>
    </g>

    <!-- Entry 2 -->
    <g transform="translate(30, 322)">
      <rect x="0" y="0" width="200" height="48" rx="8" fill="#F8F8FC"/>
      <circle cx="16" cy="24" r="6" fill="#F59E0B"/>
      <rect x="30" y="14" width="60" height="7" rx="3" fill="#1A1A2E"/>
      <rect x="30" y="26" width="48" height="6" rx="3" fill="#8888A0"/>
      <text x="170" y="20" text-anchor="end" font-family="system-ui" font-weight="700" font-size="11" fill="#1A1A2E">1:30h</text>
      <text x="170" y="32" text-anchor="end" font-family="system-ui" font-weight="400" font-size="9" fill="#10B981">fertig</text>
    </g>

    <!-- Entry 3 - current -->
    <g transform="translate(30, 376)">
      <rect x="0" y="0" width="200" height="48" rx="8" fill="#E8F2FF" stroke="#0066CC" stroke-width="1">
        <animate attributeName="opacity" values="0.7;1;0.7" dur="2s" repeatCount="indefinite"/>
      </rect>
      <circle cx="16" cy="24" r="6" fill="#0066CC">
        <animate attributeName="r" values="5;6;5" dur="1.5s" repeatCount="indefinite"/>
      </circle>
      <rect x="30" y="14" width="72" height="7" rx="3" fill="#0066CC"/>
      <rect x="30" y="26" width="56" height="6" rx="3" fill="#4A4A68"/>
      <text x="170" y="20" text-anchor="end" font-family="system-ui" font-weight="700" font-size="11" fill="#0066CC">3:24h</text>
      <text x="170" y="32" text-anchor="end" font-family="system-ui" font-weight="400" font-size="9" fill="#0066CC">läuft...</text>
    </g>

    <!-- Bottom Nav -->
    <g transform="translate(18, 438)">
      <rect x="0" y="0" width="224" height="44" rx="0" fill="#F8F8FC"/>
      <rect x="0" y="0" width="224" height="1" fill="#E2E2EA"/>
      <!-- Nav items -->
      <g transform="translate(24, 8)" opacity="0.4">
        <rect x="4" y="0" width="16" height="2" rx="1" fill="#4A4A68"/>
        <rect x="0" y="6" width="24" height="2" rx="1" fill="#4A4A68"/>
        <rect x="4" y="12" width="16" height="2" rx="1" fill="#4A4A68"/>
        <text x="12" y="26" text-anchor="middle" font-family="system-ui" font-weight="500" font-size="7" fill="#8888A0">Mehr</text>
      </g>
      <g transform="translate(92, 8)">
        <circle cx="12" cy="7" r="7" fill="none" stroke="#0066CC" stroke-width="2"/>
        <line x1="12" y1="4" x2="12" y2="7" stroke="#0066CC" stroke-width="2" stroke-linecap="round"/>
        <line x1="12" y1="7" x2="15" y2="9" stroke="#0066CC" stroke-width="2" stroke-linecap="round"/>
        <text x="12" y="26" text-anchor="middle" font-family="system-ui" font-weight="700" font-size="7" fill="#0066CC">Timer</text>
      </g>
      <g transform="translate(168, 8)" opacity="0.4">
        <rect x="0" y="0" width="20" height="14" rx="3" fill="none" stroke="#4A4A68" stroke-width="1.5"/>
        <rect x="4" y="4" width="12" height="2" rx="1" fill="#4A4A68"/>
        <rect x="4" y="8" width="8" height="2" rx="1" fill="#4A4A68"/>
        <text x="10" y="26" text-anchor="middle" font-family="system-ui" font-weight="500" font-size="7" fill="#8888A0">Berichte</text>
      </g>
    </g>

    <!-- Home indicator -->
    <rect x="95" y="472" width="70" height="4" rx="2" fill="#1A1A2E" opacity="0.3"/>
  </svg>

  <!-- Glow effects -->
  <div class="absolute top-1/4 -right-8 w-32 h-32 bg-primary/10 rounded-full blur-2xl animate-pulse"></div>
  <div class="absolute bottom-1/4 -left-8 w-24 h-24 bg-primary/5 rounded-full blur-xl animate-pulse" style="animation-delay: 1.5s"></div>
</div>
