---
// Animated dashboard mockup for hero sections
---
<div class="relative w-full max-w-lg mx-auto">
  <svg viewBox="0 0 560 400" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-auto drop-shadow-2xl">
    <!-- Browser Frame -->
    <rect x="0" y="0" width="560" height="400" rx="12" fill="#ffffff" stroke="#E2E2EA" stroke-width="1.5"/>
    <rect x="0" y="0" width="560" height="36" rx="12" fill="#F8F8FC"/>
    <rect x="0" y="24" width="560" height="12" fill="#F8F8FC"/>
    <circle cx="20" cy="18" r="5" fill="#FF5F57"/>
    <circle cx="38" cy="18" r="5" fill="#FFBD2E"/>
    <circle cx="56" cy="18" r="5" fill="#28CA41"/>
    <rect x="180" y="11" width="200" height="14" rx="7" fill="#E2E2EA"/>

    <!-- Sidebar -->
    <rect x="0" y="36" width="140" height="364" fill="#1A1A2E" rx="0"/>
    <rect x="0" y="388" width="140" height="12" rx="0" fill="#1A1A2E"/>
    <!-- Logo area -->
    <rect x="16" y="52" width="24" height="24" rx="6" fill="#0066CC"/>
    <rect x="48" y="56" width="72" height="8" rx="4" fill="rgba(255,255,255,0.6)"/>
    <rect x="48" y="68" width="48" height="6" rx="3" fill="rgba(255,255,255,0.3)"/>

    <!-- Nav items -->
    <g>
      <rect x="12" y="100" width="116" height="32" rx="6" fill="#0066CC" opacity="0.2">
        <animate attributeName="opacity" values="0.2;0.35;0.2" dur="3s" repeatCount="indefinite"/>
      </rect>
      <rect x="24" y="108" width="16" height="16" rx="4" fill="#0066CC" opacity="0.8"/>
      <rect x="48" y="112" width="64" height="8" rx="4" fill="rgba(255,255,255,0.9)"/>
    </g>
    <g opacity="0.5">
      <rect x="24" y="148" width="16" height="16" rx="4" fill="rgba(255,255,255,0.4)"/>
      <rect x="48" y="152" width="56" height="8" rx="4" fill="rgba(255,255,255,0.4)"/>
    </g>
    <g opacity="0.5">
      <rect x="24" y="180" width="16" height="16" rx="4" fill="rgba(255,255,255,0.4)"/>
      <rect x="48" y="184" width="48" height="8" rx="4" fill="rgba(255,255,255,0.4)"/>
    </g>
    <g opacity="0.5">
      <rect x="24" y="212" width="16" height="16" rx="4" fill="rgba(255,255,255,0.4)"/>
      <rect x="48" y="216" width="60" height="8" rx="4" fill="rgba(255,255,255,0.4)"/>
    </g>

    <!-- Main Content Area -->
    <!-- Header -->
    <rect x="160" y="52" width="180" height="12" rx="4" fill="#1A1A2E"/>
    <rect x="160" y="70" width="120" height="8" rx="4" fill="#8888A0"/>

    <!-- Stats Cards -->
    <g>
      <rect x="160" y="96" width="120" height="72" rx="8" fill="#F8F8FC" stroke="#E2E2EA" stroke-width="1"/>
      <rect x="176" y="112" width="48" height="6" rx="3" fill="#8888A0"/>
      <text x="176" y="140" font-family="system-ui" font-weight="900" font-size="22" fill="#1A1A2E">
        <tspan>127:30</tspan>
        <animate attributeName="opacity" values="1;0.7;1" dur="2s" repeatCount="indefinite"/>
      </text>
      <rect x="176" y="150" width="36" height="6" rx="3" fill="#10B981"/>
    </g>
    <g>
      <rect x="292" y="96" width="120" height="72" rx="8" fill="#F8F8FC" stroke="#E2E2EA" stroke-width="1"/>
      <rect x="308" y="112" width="56" height="6" rx="3" fill="#8888A0"/>
      <text x="308" y="140" font-family="system-ui" font-weight="900" font-size="22" fill="#1A1A2E">12:45</text>
      <rect x="308" y="150" width="48" height="6" rx="3" fill="#F59E0B"/>
    </g>
    <g>
      <rect x="424" y="96" width="120" height="72" rx="8" fill="#F8F8FC" stroke="#E2E2EA" stroke-width="1"/>
      <rect x="440" y="112" width="44" height="6" rx="3" fill="#8888A0"/>
      <text x="440" y="140" font-family="system-ui" font-weight="900" font-size="22" fill="#0066CC">94%</text>
      <rect x="440" y="150" width="88" height="6" rx="3" fill="#E2E2EA"/>
      <rect x="440" y="150" width="83" height="6" rx="3" fill="#0066CC">
        <animate attributeName="width" values="60;83;60" dur="4s" repeatCount="indefinite"/>
      </rect>
    </g>

    <!-- Chart Area -->
    <rect x="160" y="184" width="252" height="140" rx="8" fill="#F8F8FC" stroke="#E2E2EA" stroke-width="1"/>
    <rect x="176" y="200" width="80" height="8" rx="4" fill="#1A1A2E"/>
    <!-- Bar Chart -->
    <g transform="translate(176, 296)">
      <rect x="0" y="0" width="28" height="-56" rx="4" fill="#0066CC" opacity="0.7">
        <animate attributeName="height" values="-40;-56;-40" dur="3s" repeatCount="indefinite"/>
        <animate attributeName="y" values="0;0;0" dur="3s" repeatCount="indefinite"/>
      </rect>
      <rect x="36" y="0" width="28" height="-72" rx="4" fill="#0066CC" opacity="0.8">
        <animate attributeName="height" values="-60;-72;-60" dur="3.5s" repeatCount="indefinite"/>
      </rect>
      <rect x="72" y="0" width="28" height="-48" rx="4" fill="#0066CC" opacity="0.6">
        <animate attributeName="height" values="-36;-48;-36" dur="2.8s" repeatCount="indefinite"/>
      </rect>
      <rect x="108" y="0" width="28" height="-64" rx="4" fill="#0066CC" opacity="0.75">
        <animate attributeName="height" values="-50;-64;-50" dur="3.2s" repeatCount="indefinite"/>
      </rect>
      <rect x="144" y="0" width="28" height="-80" rx="4" fill="#0066CC">
        <animate attributeName="height" values="-65;-80;-65" dur="3.8s" repeatCount="indefinite"/>
      </rect>
    </g>

    <!-- Time Entries List -->
    <rect x="424" y="184" width="120" height="140" rx="8" fill="#F8F8FC" stroke="#E2E2EA" stroke-width="1"/>
    <rect x="436" y="200" width="56" height="8" rx="4" fill="#1A1A2E"/>
    <!-- Entry rows -->
    <g>
      <rect x="436" y="220" width="96" height="20" rx="4" fill="white" stroke="#E2E2EA" stroke-width="0.5"/>
      <circle cx="448" cy="230" r="4" fill="#10B981">
        <animate attributeName="r" values="3;4;3" dur="2s" repeatCount="indefinite"/>
      </circle>
      <rect x="458" y="226" width="40" height="4" rx="2" fill="#4A4A68"/>
      <rect x="504" y="226" width="20" height="4" rx="2" fill="#8888A0"/>
    </g>
    <g>
      <rect x="436" y="244" width="96" height="20" rx="4" fill="white" stroke="#E2E2EA" stroke-width="0.5"/>
      <circle cx="448" cy="254" r="4" fill="#0066CC"/>
      <rect x="458" y="250" width="48" height="4" rx="2" fill="#4A4A68"/>
      <rect x="510" y="250" width="16" height="4" rx="2" fill="#8888A0"/>
    </g>
    <g>
      <rect x="436" y="268" width="96" height="20" rx="4" fill="white" stroke="#E2E2EA" stroke-width="0.5"/>
      <circle cx="448" cy="278" r="4" fill="#0066CC"/>
      <rect x="458" y="274" width="36" height="4" rx="2" fill="#4A4A68"/>
      <rect x="498" y="274" width="24" height="4" rx="2" fill="#8888A0"/>
    </g>
    <g>
      <rect x="436" y="292" width="96" height="20" rx="4" fill="white" stroke="#E2E2EA" stroke-width="0.5"/>
      <circle cx="448" cy="302" r="4" fill="#F59E0B"/>
      <rect x="458" y="298" width="44" height="4" rx="2" fill="#4A4A68"/>
      <rect x="506" y="298" width="18" height="4" rx="2" fill="#8888A0"/>
    </g>

    <!-- Floating Timer Button -->
    <g transform="translate(490, 52)">
      <rect width="54" height="28" rx="14" fill="#0066CC">
        <animate attributeName="opacity" values="1;0.85;1" dur="1.5s" repeatCount="indefinite"/>
      </rect>
      <circle cx="14" cy="14" r="6" fill="none" stroke="white" stroke-width="1.5"/>
      <line x1="14" y1="10" x2="14" y2="14" stroke="white" stroke-width="1.5" stroke-linecap="round">
        <animateTransform attributeName="transform" type="rotate" from="0 14 14" to="360 14 14" dur="8s" repeatCount="indefinite"/>
      </line>
      <text x="30" y="18" font-family="system-ui" font-weight="700" font-size="10" fill="white">Start</text>
    </g>
  </svg>

  <!-- Floating decorative elements -->
  <div class="absolute -top-4 -right-4 w-20 h-20 bg-primary/10 rounded-full blur-xl animate-pulse"></div>
  <div class="absolute -bottom-6 -left-6 w-24 h-24 bg-primary/5 rounded-full blur-2xl animate-pulse" style="animation-delay: 1s"></div>
</div>
