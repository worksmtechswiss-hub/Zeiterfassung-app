---
// Animated timer/clock for time tracking sections
---
<div class="relative w-full max-w-md mx-auto">
  <svg viewBox="0 0 400 320" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-auto">
    <!-- Background card -->
    <rect x="40" y="20" width="320" height="280" rx="16" fill="white" stroke="#E2E2EA" stroke-width="1.5" filter="url(#shadow1)"/>

    <!-- Header bar -->
    <rect x="40" y="20" width="320" height="48" rx="16" fill="#F8F8FC"/>
    <rect x="40" y="52" width="320" height="16" fill="#F8F8FC"/>
    <rect x="60" y="36" width="80" height="8" rx="4" fill="#1A1A2E"/>
    <rect x="60" y="48" width="120" height="6" rx="3" fill="#8888A0"/>

    <!-- Big Timer Circle -->
    <circle cx="200" cy="160" r="70" fill="#F8F8FC" stroke="#E2E2EA" stroke-width="2"/>
    <circle cx="200" cy="160" r="70" fill="none" stroke="#0066CC" stroke-width="4" stroke-linecap="round" stroke-dasharray="440" stroke-dashoffset="110" transform="rotate(-90 200 160)">
      <animate attributeName="stroke-dashoffset" values="440;110;440" dur="12s" repeatCount="indefinite"/>
    </circle>

    <!-- Timer Display -->
    <text x="200" y="152" text-anchor="middle" font-family="system-ui" font-weight="900" font-size="28" fill="#1A1A2E">
      02:34
    </text>
    <text x="200" y="172" text-anchor="middle" font-family="system-ui" font-weight="400" font-size="11" fill="#8888A0">
      Stunden heute
    </text>

    <!-- Clock hands -->
    <line x1="200" y1="160" x2="200" y2="110" stroke="#0066CC" stroke-width="2.5" stroke-linecap="round">
      <animateTransform attributeName="transform" type="rotate" from="0 200 160" to="360 200 160" dur="8s" repeatCount="indefinite"/>
    </line>
    <line x1="200" y1="160" x2="200" y2="120" stroke="#1A1A2E" stroke-width="1.5" stroke-linecap="round" opacity="0.5">
      <animateTransform attributeName="transform" type="rotate" from="0 200 160" to="360 200 160" dur="60s" repeatCount="indefinite"/>
    </line>
    <circle cx="200" cy="160" r="4" fill="#0066CC"/>

    <!-- Start/Stop Button -->
    <g transform="translate(160, 245)">
      <rect width="80" height="36" rx="18" fill="#0066CC">
        <animate attributeName="opacity" values="1;0.85;1" dur="2s" repeatCount="indefinite"/>
      </rect>
      <!-- Play icon -->
      <polygon points="30,12 30,24 42,18" fill="white">
        <animate attributeName="opacity" values="1;0;1" dur="4s" repeatCount="indefinite"/>
      </polygon>
      <!-- Pause icon (shows when play hides) -->
      <g>
        <animate attributeName="opacity" values="0;1;0" dur="4s" repeatCount="indefinite"/>
        <rect x="31" y="12" width="4" height="12" rx="1" fill="white"/>
        <rect x="39" y="12" width="4" height="12" rx="1" fill="white"/>
      </g>
      <text x="52" y="22" font-family="system-ui" font-weight="700" font-size="10" fill="white">Start</text>
    </g>

    <!-- Project Tags -->
    <g transform="translate(60, 78)">
      <rect width="100" height="24" rx="12" fill="#E8F2FF" stroke="#0066CC" stroke-width="1" opacity="0.8"/>
      <circle cx="14" cy="12" r="4" fill="#0066CC"/>
      <text x="24" y="16" font-family="system-ui" font-weight="600" font-size="9" fill="#0066CC">Projekt Alpha</text>
    </g>
    <g transform="translate(170, 78)">
      <rect width="84" height="24" rx="12" fill="#F8F8FC" stroke="#E2E2EA" stroke-width="1"/>
      <circle cx="14" cy="12" r="4" fill="#10B981"/>
      <text x="24" y="16" font-family="system-ui" font-weight="600" font-size="9" fill="#4A4A68">Kunde B</text>
    </g>
    <g transform="translate(264, 78)">
      <rect width="84" height="24" rx="12" fill="#F8F8FC" stroke="#E2E2EA" stroke-width="1"/>
      <circle cx="14" cy="12" r="4" fill="#F59E0B"/>
      <text x="24" y="16" font-family="system-ui" font-weight="600" font-size="9" fill="#4A4A68">Meeting</text>
    </g>

    <!-- Shadow filter -->
    <defs>
      <filter id="shadow1" x="-4" y="-2" width="368" height="320" filterUnits="userSpaceOnUse">
        <feDropShadow dx="0" dy="4" stdDeviation="12" flood-color="#1A1A2E" flood-opacity="0.08"/>
      </filter>
    </defs>
  </svg>
</div>
