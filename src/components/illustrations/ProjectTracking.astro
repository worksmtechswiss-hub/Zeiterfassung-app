---
// Animated project time tracking illustration
---
<div class="relative w-full">
  <svg viewBox="0 0 480 360" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-auto drop-shadow-xl">
    <!-- Card -->
    <rect x="0" y="0" width="480" height="360" rx="12" fill="white" stroke="#E2E2EA" stroke-width="1.5"/>

    <!-- Header -->
    <rect x="0" y="0" width="480" height="44" rx="12" fill="#F8F8FC"/>
    <rect x="0" y="32" width="480" height="12" fill="#F8F8FC"/>
    <rect x="20" y="16" width="100" height="10" rx="4" fill="#1A1A2E"/>
    <rect x="360" y="12" width="100" height="20" rx="10" fill="#0066CC"/>
    <text x="385" y="26" font-family="system-ui" font-weight="700" font-size="9" fill="white">+ Neues Projekt</text>

    <!-- Project rows -->
    <!-- Row 1 - Active -->
    <g transform="translate(20, 60)">
      <rect x="0" y="0" width="440" height="56" rx="8" fill="#E8F2FF" stroke="#0066CC" stroke-width="1" opacity="0.6">
        <animate attributeName="opacity" values="0.4;0.7;0.4" dur="3s" repeatCount="indefinite"/>
      </rect>
      <circle cx="20" cy="28" r="8" fill="#0066CC"/>
      <text x="20" y="32" text-anchor="middle" font-family="system-ui" font-weight="700" font-size="9" fill="white">W</text>
      <text x="40" y="22" font-family="system-ui" font-weight="700" font-size="12" fill="#1A1A2E">Website Redesign</text>
      <text x="40" y="38" font-family="system-ui" font-weight="400" font-size="10" fill="#4A4A68">Kunde: Digital AG</text>
      <!-- Progress bar -->
      <rect x="240" y="18" width="120" height="6" rx="3" fill="#E2E2EA"/>
      <rect x="240" y="18" width="84" height="6" rx="3" fill="#0066CC">
        <animate attributeName="width" values="70;84;70" dur="5s" repeatCount="indefinite"/>
      </rect>
      <text x="240" y="38" font-family="system-ui" font-weight="600" font-size="10" fill="#0066CC">42:30h</text>
      <text x="280" y="38" font-family="system-ui" font-weight="400" font-size="10" fill="#8888A0">/ 60h</text>
      <!-- Timer running -->
      <g transform="translate(380, 12)">
        <rect width="48" height="32" rx="8" fill="#0066CC"/>
        <circle cx="14" cy="16" r="5" fill="none" stroke="white" stroke-width="1.5"/>
        <line x1="14" y1="13" x2="14" y2="16" stroke="white" stroke-width="1.5" stroke-linecap="round">
          <animateTransform attributeName="transform" type="rotate" from="0 14 16" to="360 14 16" dur="4s" repeatCount="indefinite"/>
        </line>
        <text x="28" y="20" font-family="system-ui" font-weight="700" font-size="8" fill="white">Live</text>
      </g>
    </g>

    <!-- Row 2 -->
    <g transform="translate(20, 126)">
      <rect x="0" y="0" width="440" height="56" rx="8" fill="white" stroke="#E2E2EA" stroke-width="1"/>
      <circle cx="20" cy="28" r="8" fill="#10B981"/>
      <text x="20" y="32" text-anchor="middle" font-family="system-ui" font-weight="700" font-size="9" fill="white">A</text>
      <text x="40" y="22" font-family="system-ui" font-weight="700" font-size="12" fill="#1A1A2E">App Development</text>
      <text x="40" y="38" font-family="system-ui" font-weight="400" font-size="10" fill="#4A4A68">Kunde: StartUp GmbH</text>
      <rect x="240" y="18" width="120" height="6" rx="3" fill="#E2E2EA"/>
      <rect x="240" y="18" width="108" height="6" rx="3" fill="#10B981"/>
      <text x="240" y="38" font-family="system-ui" font-weight="600" font-size="10" fill="#10B981">108:15h</text>
      <text x="286" y="38" font-family="system-ui" font-weight="400" font-size="10" fill="#8888A0">/ 120h</text>
      <rect x="380" y="12" width="48" height="32" rx="8" fill="#F8F8FC" stroke="#E2E2EA" stroke-width="1"/>
      <text x="392" y="32" font-family="system-ui" font-weight="600" font-size="9" fill="#4A4A68">Start</text>
    </g>

    <!-- Row 3 -->
    <g transform="translate(20, 192)">
      <rect x="0" y="0" width="440" height="56" rx="8" fill="white" stroke="#E2E2EA" stroke-width="1"/>
      <circle cx="20" cy="28" r="8" fill="#F59E0B"/>
      <text x="20" y="32" text-anchor="middle" font-family="system-ui" font-weight="700" font-size="9" fill="white">B</text>
      <text x="40" y="22" font-family="system-ui" font-weight="700" font-size="12" fill="#1A1A2E">Beratung & Support</text>
      <text x="40" y="38" font-family="system-ui" font-weight="400" font-size="10" fill="#4A4A68">Kunde: Treuhand Plus</text>
      <rect x="240" y="18" width="120" height="6" rx="3" fill="#E2E2EA"/>
      <rect x="240" y="18" width="48" height="6" rx="3" fill="#F59E0B"/>
      <text x="240" y="38" font-family="system-ui" font-weight="600" font-size="10" fill="#F59E0B">16:00h</text>
      <text x="278" y="38" font-family="system-ui" font-weight="400" font-size="10" fill="#8888A0">/ 40h</text>
      <rect x="380" y="12" width="48" height="32" rx="8" fill="#F8F8FC" stroke="#E2E2EA" stroke-width="1"/>
      <text x="392" y="32" font-family="system-ui" font-weight="600" font-size="9" fill="#4A4A68">Start</text>
    </g>

    <!-- Bottom summary -->
    <g transform="translate(20, 270)">
      <rect x="0" y="0" width="440" height="70" rx="8" fill="#F8F8FC"/>
      <text x="16" y="20" font-family="system-ui" font-weight="600" font-size="10" fill="#8888A0">Diese Woche</text>
      <text x="16" y="48" font-family="system-ui" font-weight="900" font-size="24" fill="#1A1A2E">32:45</text>
      <text x="96" y="48" font-family="system-ui" font-weight="400" font-size="12" fill="#8888A0">Stunden</text>

      <!-- Mini week chart -->
      <g transform="translate(240, 10)">
        <text x="0" y="10" font-family="system-ui" font-weight="600" font-size="10" fill="#8888A0">Mo–Fr</text>
        <g transform="translate(0, 50)">
          <rect x="0" y="0" width="28" height="-32" rx="3" fill="#0066CC" opacity="0.6">
            <animate attributeName="height" values="-24;-32;-24" dur="3s" repeatCount="indefinite"/>
          </rect>
          <rect x="36" y="0" width="28" height="-40" rx="3" fill="#0066CC" opacity="0.8">
            <animate attributeName="height" values="-32;-40;-32" dur="3.5s" repeatCount="indefinite"/>
          </rect>
          <rect x="72" y="0" width="28" height="-28" rx="3" fill="#0066CC" opacity="0.5">
            <animate attributeName="height" values="-20;-28;-20" dur="2.8s" repeatCount="indefinite"/>
          </rect>
          <rect x="108" y="0" width="28" height="-36" rx="3" fill="#0066CC" opacity="0.7">
            <animate attributeName="height" values="-28;-36;-28" dur="3.2s" repeatCount="indefinite"/>
          </rect>
          <rect x="144" y="0" width="28" height="-20" rx="3" fill="#0066CC" opacity="0.4">
            <animate attributeName="height" values="-12;-20;-12" dur="2.5s" repeatCount="indefinite"/>
          </rect>
        </g>
      </g>
    </g>
  </svg>
</div>
