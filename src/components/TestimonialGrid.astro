---
interface Testimonial {
  quote: string;
  name: string;
  role: string;
  company: string;
}

interface Props {
  testimonials: Testimonial[];
  title?: string;
}

const { testimonials, title = 'Das sagen Schweizer Nutzer' } = Astro.props;
---

<section class="py-16 lg:py-24 bg-surface">
  <div class="max-w-container mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="font-outfit font-bold text-3xl lg:text-[40px] text-text text-center mb-12">
      {title}
    </h2>
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
      {testimonials.map((t) => (
        <div class="bg-white rounded-card p-6 lg:p-8 shadow-sm border border-border/50">
          <div class="flex gap-1 mb-4">
            {[...Array(5)].map(() => (
              <svg class="w-5 h-5 text-warning" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>
          <blockquote class="text-text-secondary leading-relaxed mb-6">
            &laquo;{t.quote}&raquo;
          </blockquote>
          <div>
            <p class="font-bold text-text">{t.name}</p>
            <p class="text-text-muted text-sm">{t.role}, {t.company}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
