---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import FeatureCard from '../components/FeatureCard.astro';
import SectionHeading from '../components/SectionHeading.astro';
import CTASection from '../components/CTASection.astro';
import { featureCards } from '../data/features';

const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    name: 'Features – Zeiterfassungs-App Schweiz',
    description: 'Alle Funktionen der Schweizer Zeiterfassungs-App: Timer, Projekte, Mobile App, Absenzen, Überstunden, GPS, Rapporte und mehr.',
    url: 'https://zeiterfassung-app.ch/features/',
  },
];
---

<BaseLayout
  title="Features – Zeiterfassungs-App Schweiz | Alle Funktionen im Überblick"
  description="Alle Funktionen der Schweizer Zeiterfassungs-App: Timer, Projekte, Mobile App, Absenzen, Überstunden, GPS, Rapporte und mehr."
  schema={schema}
>
  <!-- Hero -->
  <Hero
    compact={true}
    title="Alle Funktionen Ihrer Schweizer Zeiterfassungs-App"
    subtitle="Von der einfachen Zeiterfassung bis zur vollständigen Personalplanung – entdecken Sie, was unsere App für Ihr Unternehmen leisten kann."
  />

  <!-- Feature Grid -->
  <section class="py-16 lg:py-24">
    <div class="max-w-container mx-auto px-4 sm:px-6 lg:px-8">
      <SectionHeading
        title="Alles, was Sie für die Zeiterfassung brauchen"
        subtitle="10 leistungsstarke Module – perfekt abgestimmt auf die Anforderungen von Schweizer Unternehmen, Freelancern und KMU."
      />
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {featureCards.map((f) => (
          <FeatureCard icon={f.icon} title={f.title} description={f.description} />
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <CTASection
    title="Überzeugt? Jetzt kostenlos starten"
    subtitle="Alle Features im Free-Plan testen. Keine Kreditkarte nötig. Upgrade jederzeit möglich."
  />
</BaseLayout>
