---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Seite nicht gefunden – Zeiterfassung App Schweiz"
  description=""
  noindex={true}
>
  <section class="py-24 lg:py-32">
    <div class="max-w-container mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="font-outfit font-black text-8xl lg:text-9xl text-primary/20 leading-none mb-6">
        404
      </p>
      <h1 class="font-outfit font-bold text-3xl lg:text-4xl text-text leading-tight mb-4">
        Seite nicht gefunden
      </h1>
      <p class="text-text-secondary text-lg max-w-md mx-auto mb-10">
        Die gesuchte Seite existiert leider nicht. Vielleicht finden Sie hier, was Sie suchen:
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-8">
        <a
          href="/"
          class="inline-flex items-center justify-center px-8 py-3.5 bg-primary text-white font-bold text-base rounded-button hover:bg-primary-hover transition-colors shadow-lg"
        >
          Zur Startseite
        </a>
        <a
          href="/features/"
          class="inline-flex items-center justify-center px-8 py-3.5 border border-border text-text font-bold text-base rounded-button hover:bg-surface transition-colors"
        >
          Features
        </a>
        <a
          href="/preise/"
          class="inline-flex items-center justify-center px-8 py-3.5 border border-border text-text font-bold text-base rounded-button hover:bg-surface transition-colors"
        >
          Preise
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
