---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Kontakt – Zeiterfassung App Schweiz"
  description="Kontaktieren Sie uns. Fragen zur Zeiterfassungs-App? Wir sind für Sie da."
>
  <!-- Hero -->
  <section class="py-12 lg:py-16 bg-surface">
    <div class="max-w-container mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="font-outfit font-bold text-3xl lg:text-4xl text-text leading-tight">
        Kontakt
      </h1>
      <p class="mt-4 text-text-secondary text-lg max-w-xl mx-auto">
        Haben Sie Fragen zur Zeiterfassungs-App? Wir helfen Ihnen gerne weiter.
      </p>
    </div>
  </section>

  <!-- Contact Form + Info -->
  <section class="py-16 lg:py-24">
    <div class="max-w-container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-2 gap-12 lg:gap-16">

        <!-- Left: Form -->
        <div>
          <h2 class="font-outfit font-bold text-xl lg:text-2xl text-text mb-6">
            Nachricht senden
          </h2>
          <form name="kontakt" method="POST" data-netlify="true" class="space-y-5">
            <input type="hidden" name="form-name" value="kontakt" />

            <div>
              <label for="name" class="block text-sm font-bold text-text mb-1.5">
                Name <span class="text-primary">*</span>
              </label>
              <input
                type="text"
                id="name"
                name="name"
                required
                class="w-full border border-border rounded-button px-4 py-3 text-text bg-white placeholder:text-text-muted focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition-colors"
                placeholder="Ihr Name"
              />
            </div>

            <div>
              <label for="email" class="block text-sm font-bold text-text mb-1.5">
                E-Mail <span class="text-primary">*</span>
              </label>
              <input
                type="email"
                id="email"
                name="email"
                required
                class="w-full border border-border rounded-button px-4 py-3 text-text bg-white placeholder:text-text-muted focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition-colors"
                placeholder="ihre@email.ch"
              />
            </div>

            <div>
              <label for="unternehmen" class="block text-sm font-bold text-text mb-1.5">
                Unternehmen
              </label>
              <input
                type="text"
                id="unternehmen"
                name="unternehmen"
                class="w-full border border-border rounded-button px-4 py-3 text-text bg-white placeholder:text-text-muted focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition-colors"
                placeholder="Firma (optional)"
              />
            </div>

            <div>
              <label for="nachricht" class="block text-sm font-bold text-text mb-1.5">
                Nachricht <span class="text-primary">*</span>
              </label>
              <textarea
                id="nachricht"
                name="nachricht"
                required
                rows="5"
                class="w-full border border-border rounded-button px-4 py-3 text-text bg-white placeholder:text-text-muted focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition-colors resize-y"
                placeholder="Wie können wir Ihnen helfen?"
              ></textarea>
            </div>

            <button
              type="submit"
              class="inline-flex items-center justify-center px-8 py-3.5 bg-primary text-white font-bold text-base rounded-button hover:bg-primary-hover transition-colors shadow-lg"
            >
              Nachricht senden
            </button>
          </form>
        </div>

        <!-- Right: Contact Info -->
        <div class="flex flex-col gap-8 md:pt-12">
          <div>
            <h2 class="font-outfit font-bold text-xl lg:text-2xl text-text mb-4">
              Kontaktinformationen
            </h2>
            <div class="space-y-4">
              <div class="flex items-start gap-3">
                <svg class="w-5 h-5 text-primary mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
                <div>
                  <p class="text-sm font-bold text-text">E-Mail</p>
                  <a href="mailto:kontakt@zeiterfassung-app.ch" class="text-primary hover:text-primary-hover underline">
                    kontakt@zeiterfassung-app.ch
                  </a>
                </div>
              </div>
            </div>
          </div>

          <div class="flex items-start gap-3 p-4 bg-primary-light rounded-card">
            <svg class="w-5 h-5 text-primary mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <p class="text-text-secondary text-sm leading-relaxed">
              <strong class="font-bold text-text">Schnelle Antwort:</strong> Wir antworten innerhalb von 24 Stunden auf Ihre Anfrage.
            </p>
          </div>

          <div class="flex items-start gap-3 p-4 bg-surface rounded-card border border-border">
            <svg class="w-5 h-5 text-success mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
            <p class="text-text-secondary text-sm leading-relaxed">
              <strong class="font-bold text-text">Daten in der Schweiz:</strong> Sämtliche Daten werden auf Servern in der Schweiz gehostet und verarbeitet.
            </p>
          </div>
        </div>

      </div>
    </div>
  </section>
</BaseLayout>
