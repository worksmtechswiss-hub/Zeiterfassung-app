---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import SectionHeading from '../components/SectionHeading.astro';
import FeatureCard from '../components/FeatureCard.astro';
import FeatureRow from '../components/FeatureRow.astro';
import TestimonialGrid from '../components/TestimonialGrid.astro';
import FAQ from '../components/FAQ.astro';
import CTASection from '../components/CTASection.astro';
import { freelancerTestimonials } from '../data/testimonials';
import { freelancerFaq } from '../data/faq';
import { ctaUrl } from '../data/navigation';

const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: freelancerFaq.map((item) => ({
      '@type': 'Question',
      name: item.question,
      acceptedAnswer: {
        '@type': 'Answer',
        text: item.answer.replace(/<[^>]*>/g, ''),
      },
    })),
  },
];
---

<BaseLayout
  title="Zeiterfassung für Freelancer Schweiz – Projekte & Stunden einfach erfassen"
  description="Als Freelancer in der Schweiz Stunden einfach erfassen, Projektzeiten auswerten und professionelle Rapporte erstellen. Kostenlos starten."
  schema={schema}
>
  <!-- Hero -->
  <Hero
    title="Zeiterfassung für Freelancer – mehr Zeit fürs Business"
    subtitle="Erfassen Sie Projektzeiten mühelos, erstellen Sie professionelle Kundenrapporte und behalten Sie Ihre Produktivität im Blick. Für Freelancer in der Schweiz."
    cta2Text="Alle Features ansehen"
    cta2Href="/features/"
  />

  <!-- Pain Points -->
  <section class="py-16 lg:py-24">
    <div class="max-w-container mx-auto px-4 sm:px-6 lg:px-8">
      <SectionHeading
        title="Warum Freelancer auf Zeiterfassung setzen"
        subtitle="Ob Stundennachweis, Steuerabzug oder Selbstoptimierung – als Freelancer profitieren Sie dreifach."
      />
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        <FeatureCard
          icon='<svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15a2.25 2.25 0 012.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V19.5a2.25 2.25 0 002.25 2.25h.75" /></svg>'
          title="Kundennachweise"
          description="Weisen Sie Ihren Kunden exakt nach, wie viel Zeit Sie für welche Aufgabe investiert haben. Professionelle PDF-Rapporte auf Knopfdruck."
        />
        <FeatureCard
          icon='<svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0115.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 013 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 00-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 01-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 003 15h-.75M15 10.5a3 3 0 11-6 0 3 3 0 016 0zm3 0h.008v.008H18V10.5zm-12 0h.008v.008H6V10.5z" /></svg>'
          title="Steuerliche Absetzbarkeit"
          description="Dokumentierte Arbeitszeiten helfen Ihnen bei der Steuererklärung. Belegen Sie Ihre Arbeitsstunden sauber gegenüber dem Steueramt."
        />
        <FeatureCard
          icon='<svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z" /></svg>'
          title="Produktivität steigern"
          description="Analysieren Sie, wohin Ihre Zeit fliesst. Erkennen Sie unrentable Projekte und optimieren Sie Ihren Stundensatz datenbasiert."
        />
      </div>
    </div>
  </section>

  <!-- Feature Rows -->
  <section class="py-16 lg:py-24 bg-surface">
    <div class="max-w-container mx-auto px-4 sm:px-6 lg:px-8 space-y-20 lg:space-y-32">
      <FeatureRow
        title="Projekte & Kunden – alles an einem Ort"
        description="Legen Sie Projekte und Kunden an und erfassen Sie Ihre Arbeitszeit pro Auftrag. So wissen Sie jederzeit, welches Projekt wie viel Zeit beansprucht."
        features={[
          'Unbegrenzte Projekte und Kunden anlegen',
          'Zeiten per Timer oder manuell erfassen',
          'Stundensätze pro Projekt oder Kunde hinterlegen',
          'Projektfortschritt in Echtzeit verfolgen',
        ]}
        imagePosition="right"
      />
      <FeatureRow
        title="Rapporte & Exporte – professionell und schnell"
        description="Erstellen Sie Stundenrapporte als PDF für Ihre Kunden. Exportieren Sie Daten für Ihre Buchhaltung oder Steuererklärung."
        features={[
          'PDF-Rapporte mit eigenem Logo',
          'CSV- und Excel-Export für die Buchhaltung',
          'Rapporte nach Projekt, Kunde oder Zeitraum filtern',
          'Direkt per E-Mail an Kunden senden',
        ]}
        imagePosition="left"
      />
      <FeatureRow
        title="Mobile App – Zeiten erfassen, wo immer Sie arbeiten"
        description="Ob im Homeoffice, beim Kunden oder unterwegs: Mit der iOS- und Android-App erfassen Sie Zeiten in Sekunden. Auch offline."
        features={[
          'Native Apps für iOS und Android',
          'Timer mit einem Tipp starten',
          'Offline-Modus mit automatischer Synchronisation',
          'Push-Erinnerungen für vergessene Einträge',
        ]}
        imagePosition="right"
      />
    </div>
  </section>

  <!-- Testimonials -->
  <TestimonialGrid testimonials={freelancerTestimonials} title="Das sagen Schweizer Freelancer" />

  <!-- FAQ -->
  <FAQ items={freelancerFaq} title="Häufige Fragen von Freelancern" />

  <!-- CTA -->
  <CTASection
    title="Als Freelancer kostenlos starten"
    subtitle="Keine Kreditkarte nötig. In 2 Minuten startklar. Testen Sie die Zeiterfassung, die zu Ihrem Business passt."
    buttonText="Kostenlos starten"
    buttonHref={ctaUrl}
  />
</BaseLayout>
