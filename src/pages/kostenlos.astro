---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import CTASection from '../components/CTASection.astro';
import SectionHeading from '../components/SectionHeading.astro';
import FeatureCard from '../components/FeatureCard.astro';
import { ctaUrl } from '../data/navigation';
import { plan } from '../data/pricing';
---

<BaseLayout
  title="Zeiterfassung kostenlos testen – 30 Tage gratis | Schweiz"
  description="Zeiterfassung App 30 Tage kostenlos testen. Alle Features, keine Einschränkungen, keine Kreditkarte. Schweizer Qualität."
>
  <!-- Hero -->
  <Hero
    title="30 Tage kostenlos testen – alle Features inklusive"
    subtitle="Testen Sie Finito Pro unverbindlich mit allen Funktionen. Keine Kreditkarte, keine Einschränkungen. Nach 30 Tagen entscheiden Sie."
    cta1Text="Jetzt kostenlos testen"
    cta1Href={ctaUrl}
    cta2Text="Preise ansehen"
    cta2Href="/preise/"
  />

  <!-- What you get -->
  <section class="py-16 lg:py-24">
    <div class="max-w-container mx-auto px-4 sm:px-6 lg:px-8">
      <SectionHeading
        title="Was Sie in der Testphase erhalten"
        subtitle="Voller Zugang zu allen Features — genau wie im bezahlten Abo."
      />
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        <FeatureCard
          icon='<svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>'
          title="Zeiterfassung"
          description="Timer, manuelle Eingabe, Kiosk-Modus. Stunden sekundengenau erfassen."
        />
        <FeatureCard
          icon='<svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" /></svg>'
          title="Unbegrenzte Projekte"
          description="Projekte, Kunden und Aktivitäten anlegen. Stundenrapporte auf Knopfdruck."
        />
        <FeatureCard
          icon='<svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" /></svg>'
          title="Unbegrenzte Benutzer"
          description="Laden Sie Ihr ganzes Team ein. Rollen, Genehmigungen und Team-Dashboard inklusive."
        />
        <FeatureCard
          icon='<svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z" /></svg>'
          title="Mobile App"
          description="iOS und Android. Auch offline verfügbar mit automatischer Synchronisation."
        />
        <FeatureCard
          icon='<svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>'
          title="Rapporte & Exporte"
          description="PDF, CSV und Excel. ArG-konforme Zeitnachweise für Buchhaltung und Kunden."
        />
        <FeatureCard
          icon='<svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>'
          title="Schweizer Datenschutz"
          description="Alle Daten in der Schweiz. DSG-konform. Keine Datenweitergabe an Dritte."
        />
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="py-16 lg:py-24 bg-surface">
    <div class="max-w-container mx-auto px-4 sm:px-6 lg:px-8">
      <SectionHeading
        title="So einfach geht's"
        subtitle="In 3 Schritten zur professionellen Zeiterfassung."
      />
      <div class="grid md:grid-cols-3 gap-8 max-w-4xl mx-auto">
        <div class="text-center">
          <div class="w-14 h-14 bg-primary text-white rounded-full flex items-center justify-center mx-auto mb-4 font-outfit font-black text-xl">1</div>
          <h3 class="font-bold text-text mb-2">Konto erstellen</h3>
          <p class="text-text-secondary text-sm">E-Mail eingeben, Passwort wählen — fertig in 2 Minuten.</p>
        </div>
        <div class="text-center">
          <div class="w-14 h-14 bg-primary text-white rounded-full flex items-center justify-center mx-auto mb-4 font-outfit font-black text-xl">2</div>
          <h3 class="font-bold text-text mb-2">30 Tage testen</h3>
          <p class="text-text-secondary text-sm">Nutzen Sie alle Features ohne Einschränkungen. Keine Kreditkarte nötig.</p>
        </div>
        <div class="text-center">
          <div class="w-14 h-14 bg-primary text-white rounded-full flex items-center justify-center mx-auto mb-4 font-outfit font-black text-xl">3</div>
          <h3 class="font-bold text-text mb-2">Entscheiden</h3>
          <p class="text-text-secondary text-sm">Überzeugt? CHF 30/Monat. Nicht überzeugt? Konto wird einfach pausiert.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <CTASection
    title="Jetzt 30 Tage kostenlos testen"
    subtitle="Alle Features. Keine Kreditkarte. Keine Verpflichtung."
    buttonText="Kostenlos starten"
  />
</BaseLayout>
